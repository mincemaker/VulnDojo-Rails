# See https://docs.docker.com/engine/reference/builder/#dockerignore-file for more about ignoring files.

# Ignore git directory.
/.git/

# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
/.env*
!/.env*.erb

# Ignore all default key files.
/config/master.key
/config/credentials/*.key

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Ignore assets.
/node_modules/
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets

# Ignore development and testing files.
/test/
/spec/
.rspec
/coverage/

# Ignore documentation.
README.md
/docs/

# Ignore Docker and compose files (meta).
Dockerfile*
docker-compose*.yml
compose.yaml

# Ignore development tool configurations.
.claude/
.github/
.vscode/
.idea/

# Ignore OS and editor files.
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Ignore Ruby/Rails development files.
/.byebug_history
/.irb_history

# Ignore Serena files.
.serena/
