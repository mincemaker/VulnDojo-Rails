<div class="card" style="margin-bottom:16px;">
  <%= form_with(url: tasks_path, method: :get, local: true) do |f| %>
    <div style="display:flex; gap:8px;">
      <%= f.text_field :q, value: params[:q], placeholder: "タスクを検索...", style: "flex:1; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:1rem;" %>
      <%= f.hidden_field :view_type, value: params[:view_type] %>
      <%= f.submit "検索", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
