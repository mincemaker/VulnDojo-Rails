<div class="top-bar">
  <h2>タスク一覧</h2>
  <div class="actions">
    <%= link_to "📥 CSVエクスポート", export_tasks_path(format: :csv), class: "btn btn-secondary" %>
    <%= link_to "➕ 新規作成", new_task_path, class: "btn btn-primary" %>
  </div>
</div>

<% if @tasks.any? %>
  <table>
    <thead>
      <tr>
        <th>タイトル</th>
        <th>状態</th>
        <th>期限</th>
        <th>更新日時</th>
        <th>📎</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @tasks.each do |task| %>
        <tr>
          <td><%= link_to task.title, task_path(task) %></td>
          <td>
            <% if task.completed? %>
              <span class="badge badge-done">✅ 完了</span>
            <% else %>
              <span class="badge badge-todo">⏳ 未完了</span>
            <% end %>
          </td>
          <td><%= task.due_date&.strftime("%Y-%m-%d") || "—" %></td>
          <td><%= task.updated_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
          <td><%= task.attachment.attached? ? "📎" : "" %></td>
          <td>
            <div class="actions">
              <%= link_to "編集", edit_task_path(task), class: "btn btn-secondary btn-sm" %>
              <%= button_to "削除", task_path(task), method: :delete, class: "btn btn-danger btn-sm", form: { data: { turbo_confirm: "削除してよろしいですか？" } } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="card" style="text-align:center; color:#6b7280;">
    <p>タスクがまだありません。「新規作成」から追加しましょう！</p>
  </div>
<% end %>
