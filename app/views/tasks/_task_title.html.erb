<div class="detail-row">
  <div class="label">タイトル</div>
  <div>
    <% if @task.color.present? && @task.color.match?(/\A#[0-9a-fA-F]{3,6}\z/) %>
      <span style="display:inline-block; width:16px; height:16px; background-color:<%= @task.color %>; border:1px solid #ccc; border-radius:50%; margin-right:8px; vertical-align:middle;"></span>
    <% end %>
    <%= @task.title %>
  </div>
</div>
