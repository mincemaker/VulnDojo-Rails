<%= form_with(model: task, class: "card", multipart: true) do |form| %>
  <% if task.errors.any? %>
    <div class="errors">
      <strong><%= task.errors.count %>件のエラーがあります:</strong>
      <ul>
        <% task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :title, "タイトル" %>
    <%= form.text_field :title %>
  </div>

  <div class="form-group">
    <%= form.label :description, "説明" %>
    <%= form.text_area :description %>
  </div>

  <div class="form-group">
    <%= form.label :due_date, "期限" %>
    <%= form.date_field :due_date %>
  </div>

  <div class="form-group">
    <%= form.label :url, "URL" %>
    <%= form.url_field :url, placeholder: "https://example.com" %>
  </div>

  <div class="form-group">
    <%= form.label :secret_note, "秘密メモ" %>
    <%= form.text_area :secret_note, rows: 2, placeholder: "ログに記録されない機密情報" %>
  </div>

  <div class="form-group">
    <%= form.label :attachment, "添付ファイル" %>
    <%= form.file_field :attachment %>
    <% if task.persisted? && task.attachment.attached? %>
      <div class="attachment-info" style="margin-top: 6px;">
        📎 現在: <%= task.attachment.filename %>
      </div>
    <% end %>
  </div>

  <div class="form-group">
    <%= form.label :completed, "完了" %>
    <%= form.check_box :completed %>
  </div>

  <div class="actions">
    <%= form.submit "保存", class: "btn btn-primary" %>
    <%= link_to "キャンセル", tasks_path, class: "btn btn-secondary" %>
  </div>
<% end %>
